#!/usr/bin/withcontenv bash

# Template msmtp config from environment variables
if [ -n "${SMTP_HOST:-}" ]; then
    cat > /etc/msmtprc <<SMTPCONF
defaults
auth           on
tls            ${SMTP_TLS:-on}
tls_trust_file /etc/ssl/certs/ca-certificates.crt
syslog         on

account        smtp
host           ${SMTP_HOST}
port           ${SMTP_PORT:-587}
from           ${SMTP_FROM:-${SMTP_USER}}
user           ${SMTP_USER}
password       ${SMTP_PASS}

account default : smtp
SMTPCONF
    chmod 600 /etc/msmtprc
    ln -sf /usr/bin/msmtp /usr/sbin/sendmail 2>/dev/null || true
    echo "[msmtp] Configured for ${SMTP_HOST}:${SMTP_PORT:-587}"
else
    echo "[msmtp] No SMTP_HOST set, email alerts disabled"
fi
